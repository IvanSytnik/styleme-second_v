# ===== Core =====
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=info

# ===== Replicate =====
REPLICATE_API_TOKEN=r8_your_token_here

# ===== Supabase =====
# Get these at: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJh...
SUPABASE_SERVICE_ROLE_KEY=eyJh...
# Get this at: Project Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret-here

# ===== Upstash Redis =====

# Get these at: https://console.upstash.com — open your DB → "REST API" tab
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=AY...

# NOTE:
# In development you can leave Supabase + Upstash empty — the API falls
# back to a deterministic dev user and an in-memory Redis. Production
# refuses to start without all of the above.
